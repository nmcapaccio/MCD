# NOTE: Este archivo se deriva de `gitignore` (legacy) en la raíz.
# Mantener `.gitignore` como fuente canónica para que Git lo respete.

# ─── Sistema operativo ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Variables de entorno y secretos ─────────────────────────────────
.env
.env.local
.env.development
.env.staging
.env.production
.env.*.local
*.pem
*.key
*.p8
*.p12
*.mobileprovision

# ─── Node / npm / yarn / pnpm ────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
# Descomentar si se usa yarn:
# yarn.lock

# ─── Build outputs ───────────────────────────────────────────────────
dist/
build/
out/
.next/
.expo/
.expo-shared/
web-build/
*.tsbuildinfo

# ─── Expo / React Native ─────────────────────────────────────────────
.expo/
ios/
android/
*.orig.*
*.jks
*.keystore
google-services.json
GoogleService-Info.plist

# ─── Supabase ─────────────────────────────────────────────────────────
supabase/.branches/
supabase/.temp/
# El archivo config.toml SÍ se versiona (sin secretos)
# Los secretos van en variables de entorno del CI/CD

# ─── TypeScript ───────────────────────────────────────────────────────
*.js.map
*.d.ts.map

# ─── Testing ──────────────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/
*.lcov

# ─── Logs ─────────────────────────────────────────────────────────────
logs/
*.log
lerna-debug.log*

# ─── Editores ─────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
# Mantener .vscode/extensions.json si se quiere compartir extensiones recomendadas
.idea/
*.swp
*.swo
*~

# ─── Cursor ───────────────────────────────────────────────────────────
# El archivo CURSOR_PROMPT.md SÍ se versiona — es documentación del proyecto
.cursor/

# ─── Archivos temporales y caché ──────────────────────────────────────
.cache/
.turbo/
.parcel-cache/
tmp/
temp/
*.tmp

# ─── Datos de desarrollo / seeds sensibles ────────────────────────────
# El seed.sql genérico SÍ se versiona
# Datos reales de pacientes NUNCA se versionen
supabase/seed-production.sql
supabase/dump*.sql
exports/
